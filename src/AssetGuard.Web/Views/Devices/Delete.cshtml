@model Device
@{ ViewData["Title"] = "Delete Device"; }

<div class="page-header"><h1>Delete Device</h1></div>

<div class="card table-card border-danger">
    <div class="card-body">
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> This action cannot be undone.</div>
        <dl class="row mb-0">
            <dt class="col-sm-3">Asset Tag</dt><dd class="col-sm-9">@Model.AssetTag</dd>
            <dt class="col-sm-3">Device</dt><dd class="col-sm-9">@Model.DeviceName</dd>
        </dl>
        <form asp-action="Delete" method="post" class="mt-4"
              data-confirm="Are you sure you want to permanently delete this device?"
              data-confirm-title="Delete Device"
              data-confirm-btn="Delete">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete Device</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
