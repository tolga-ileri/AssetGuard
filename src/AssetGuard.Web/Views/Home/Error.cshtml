@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-octagon display-1 text-danger"></i>
    <h2 class="mt-3">Something went wrong</h2>
    <p class="text-muted">An unexpected error occurred. Please try again or contact your administrator.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary mt-3">Return to Dashboard</a>
</div>
