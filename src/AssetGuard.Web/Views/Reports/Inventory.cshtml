@model InventoryReportViewModel
@{ ViewData["Title"] = "Inventory Report"; ViewBag.Departments = Model.Departments; ViewBag.ExportAction = "ExportInventory"; ViewBag.ShowDepartment = false; }

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1>Inventory Report</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a asp-action="Index">Reports</a></li><li class="breadcrumb-item active">Inventory</li></ol></nav>
    </div>
    <span class="badge bg-light text-dark border">@Model.Rows.Count records</span>
</div>

<partial name="_ReportFilter" model="Model.Filter" />

<div class="card table-card">
    @if (Model.Rows.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th>Asset Tag</th><th>Serial</th><th>Device</th><th>Type</th><th>Brand/Model</th><th>Status</th><th>Location</th><th>Purchase Date</th><th>Warranty End</th></tr></thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        <tr>
                            <td><strong>@r.AssetTag</strong></td><td>@r.SerialNumber</td><td>@r.DeviceName</td>
                            <td><span class="badge bg-light text-dark border">@r.DeviceType</span></td>
                            <td>@r.Brand @r.Model</td>
                            <td><partial name="_StatusBadge" model="@r.Status" /></td>
                            <td>@(r.Location ?? "—")</td>
                            <td>@r.PurchaseDate.ToString("MMM d, yyyy")</td>
                            <td>@(r.WarrantyEndDate?.ToString("MMM d, yyyy") ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card-body"><partial name="_EmptyState" view-data='new ViewDataDictionary(ViewData) { {"EmptyIcon","bi-laptop"}, {"EmptyTitle","No devices match filters"} }' /></div>
    }
</div>
