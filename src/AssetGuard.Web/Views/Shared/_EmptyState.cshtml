@{
    var icon = ViewBag.EmptyIcon as string ?? "bi-inbox";
    var title = ViewBag.EmptyTitle as string ?? "No records found";
    var message = ViewBag.EmptyMessage as string ?? "Try adjusting your filters or add new data.";
    var actionUrl = ViewBag.EmptyActionUrl as string;
    var actionText = ViewBag.EmptyActionText as string;
}

<div class="text-center py-5">
    <i class="bi @icon display-4 text-muted"></i>
    <h5 class="mt-3 text-muted">@title</h5>
    <p class="text-muted small mb-3">@message</p>
    @if (!string.IsNullOrEmpty(actionUrl))
    {
        <a href="@actionUrl" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> @actionText</a>
    }
</div>
