<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssetGuard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function () {
            var t = localStorage.getItem('assetguard-theme');
            if (t === 'dark' || t === 'light') document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="admin-wrapper">
            <div class="sidebar-overlay" id="sidebarOverlay"></div>
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-brand">
                    <i class="bi bi-shield-check"></i> AssetGuard
                </div>
                <nav class="sidebar-nav">
                    @{
                        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                    }
                    <a class="nav-link @(controller == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a class="nav-link @(controller == "Devices" ? "active" : "")" asp-controller="Devices" asp-action="Index">
                        <i class="bi bi-laptop"></i> Devices
                    </a>
                    <a class="nav-link @(controller == "Employees" ? "active" : "")" asp-controller="Employees" asp-action="Index">
                        <i class="bi bi-people"></i> Employees
                    </a>
                    <a class="nav-link @(controller == "Assignments" ? "active" : "")" asp-controller="Assignments" asp-action="Index">
                        <i class="bi bi-arrow-left-right"></i> Assignments
                    </a>
                    <a class="nav-link @(controller == "Maintenance" ? "active" : "")" asp-controller="Maintenance" asp-action="Index">
                        <i class="bi bi-tools"></i> Maintenance
                    </a>
                    <a class="nav-link @(controller == "Warranties" ? "active" : "")" asp-controller="Warranties" asp-action="Index">
                        <i class="bi bi-file-earmark-check"></i> Warranties
                    </a>
                    <a class="nav-link @(controller == "Reports" ? "active" : "")" asp-controller="Reports" asp-action="Index">
                        <i class="bi bi-bar-chart-line"></i> Reports
                    </a>
                    <a class="nav-link @(controller == "AuditLogs" ? "active" : "")" asp-controller="AuditLogs" asp-action="Index">
                        <i class="bi bi-journal-text"></i> Audit Logs
                    </a>
                    @if (User.IsInRole(UserRoles.Admin))
                    {
                        <a class="nav-link @(controller == "Users" ? "active" : "")" asp-controller="Users" asp-action="Index">
                            <i class="bi bi-shield-lock"></i> Users
                        </a>
                    }
                </nav>
            </aside>
            <div class="main-content">
                <header class="topbar">
                    <div>
                        <button class="btn btn-sm btn-outline-secondary d-lg-none" type="button" data-sidebar-toggle>
                            <i class="bi bi-list"></i>
                        </button>
                    </div>
                    <div class="d-flex align-items-center gap-2 gap-md-3">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="themeToggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                            <i class="bi bi-moon-stars" id="themeIcon"></i>
                        </button>
                        <span class="text-muted small d-none d-md-inline">
                            <i class="bi bi-person-circle"></i>
                            @(User.FindFirst("FullName")?.Value ?? User.Identity?.Name)
                        </span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </button>
                        </form>
                    </div>
                </header>
                <div class="content-area">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </div>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await Html.PartialAsync("_ConfirmModal")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
